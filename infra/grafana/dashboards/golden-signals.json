  "liveNow": false,
  "panels": [
    {
      "title": "Latency - HTTP Request Duration P95 (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"canbankx-customer-service\"}[5m])) by (le))",
          "legendFormat": "P95 Latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Traffic - Requests Per Second",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"canbankx-customer-service\"}[5m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Errors - 4xx/5xx Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"canbankx-customer-service\",status=~\"4..|5..\"}[5m]))",
          "legendFormat": "Error Rate"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"canbankx-customer-service\",status=~\"4..\"}[5m]))",
          "legendFormat": "4xx Rate"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"canbankx-customer-service\",status=~\"5..\"}[5m]))",
          "legendFormat": "5xx Rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Saturation - JVM Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"canbankx-customer-service\",area=\"heap\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"canbankx-customer-service\",area=\"heap\"}",
          "legendFormat": "Heap Max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "title": "Saturation - CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "system_cpu_usage{application=\"canbankx-customer-service\"}",
          "legendFormat": "System CPU"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "JVM Threads",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"canbankx-customer-service\"}",
          "legendFormat": "Live Threads"
        }
      ]
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"canbankx-customer-service\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"canbankx-customer-service\"}",
          "legendFormat": "Idle"
        },
        {
          "expr": "hikaricp_connections_max{application=\"canbankx-customer-service\"}",
          "legendFormat": "Max"
        }
      ]
    }
  ],
